# ============================================================
# File nay la MAU (template). Copy thanh .env roi dien gia tri that:
#   cp .env.example .env
# .env KHONG duoc commit len git (da trong .gitignore).
#
# 5 NHOM BIEN (xem chi tiet trong tai lieu du an):
#   Nhom 1: terraform.tfvars      -> KHONG xuat hien o day
#   Nhom 2: Terraform output      -> dien tay sau khi terraform apply
#   Nhom 3: Local-only            -> KHONG day len GitHub Secrets
#   Nhom 4: Local + GitHub Secrets -> can cho ca local va CI
#   Nhom 5: CI tu tinh            -> de trong, CI tu dien
# ============================================================

# ── NHOM 4: Secret dung chung (local + GitHub Secrets) ────────
# Generate: openssl rand -hex 32
INTERNAL_SECRET=change-me-use-openssl-rand-hex-32
# Generate: openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ── NHOM 2: Dien sau khi "terraform apply" xong ────────────────
# Lay bang: terraform output -raw master_public_ip
MASTER_NODE_IP=
# Lay bang: terraform output -raw github_actions_role_arn
AWS_GITHUB_ACTIONS_ROLE_ARN=
# Duong dan file .pem - script tu doc va day NGUYEN VAN (nhieu dong)
# len GitHub Secrets, KHONG dan private key truc tiep vao day.
MASTER_SSH_PRIVATE_KEY_FILE=~/.ssh/aiops-keypair.pem

# ── NHOM 4: AWS Account (dien tay) ─────────────────────────────
AWS_ACCOUNT_ID=

# ── NHOM 5: CI tu tinh luc deploy - de trong khong sao ─────────
AI_ENGINE_IMAGE=
WORKER_IMAGE=

# ── NHOM 3: Local-only (KHONG day len GitHub) ──────────────────
AWS_PROFILE=aiops-terraform
AWS_REGION=ap-southeast-1
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
WORKER_ORCHESTRATOR_URL=http://worker-orchestrator:8050
GITHUB_REPO=your-username/aiops-traffic-shaper
NGINX_RATE_LIMIT_RPS=50
NGINX_RATE_LIMIT_BURST=100
NGINX_STRICT_RATE_LIMIT_RPS=5
NGINX_STRICT_RATE_LIMIT_BURST=10

# ── NHOM 3 (tiep, cung local-only): cau hinh AI Engine/Worker ──
# LUU Y QUAN TRONG: cac gia tri duoi day HIEN DANG BI HARDCODE
# thang trong k8s/ai-engine/deployment.yaml va
# k8s/worker-orchestrator/deployment.yaml. Doi o day KHONG anh
# huong gi den cluster that - chi la gia tri tham khao/du phong.
# Muon doi that su phai sua truc tiep file YAML tuong ung.
SHADOW_MODE=true
WINDOW_SECONDS=5
WINDOW_TTL_SECONDS=10
MIN_REQUESTS_THRESHOLD=3
MODEL_CONTAMINATION=0.01
TIER1_SCORE_THRESHOLD=-0.1
TIER2_SCORE_THRESHOLD=-0.3
WHITELIST_REDIS_KEY=whitelist:ips
REPUTATION_REDIS_KEY=reputation:blacklist
RETRAIN_INTERVAL_HOURS=24
SHADOW_MODE_HOURS=24
REDIS_STREAM_MAXLEN=500000
NAMESPACE=aiops
BLOCKLIST_CONFIGMAP=nginx-blocklist
TIER1_TTL_SECONDS=300
TIER2_TTL_SECONDS=3600
CLEANUP_INTERVAL_SECONDS=60
MITIGATION_KEY_PREFIX=mitigation
WHITELIST_KEY=whitelist:ips
