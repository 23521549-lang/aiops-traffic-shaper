# ── Internal Authentication ───────────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=change-me-use-openssl-rand-hex-32

# ── Grafana (tách riêng khỏi INTERNAL_SECRET) ────────────────────
# Generate with: openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── AI Engine ─────────────────────────────────────────────────────
SHADOW_MODE=true
WINDOW_SECONDS=5
WINDOW_TTL_SECONDS=10
MIN_REQUESTS_THRESHOLD=3
MODEL_CONTAMINATION=0.01
TIER1_SCORE_THRESHOLD=-0.1
TIER2_SCORE_THRESHOLD=-0.3
WORKER_ORCHESTRATOR_URL=http://worker-orchestrator:8050
WHITELIST_REDIS_KEY=whitelist:ips
REPUTATION_REDIS_KEY=reputation:blacklist
RETRAIN_INTERVAL_HOURS=24
SHADOW_MODE_HOURS=24
REDIS_STREAM_MAXLEN=500000

# ── Worker Orchestrator ───────────────────────────────────────────
NAMESPACE=aiops
BLOCKLIST_CONFIGMAP=nginx-blocklist
TIER1_TTL_SECONDS=300
TIER2_TTL_SECONDS=3600
CLEANUP_INTERVAL_SECONDS=60
MITIGATION_KEY_PREFIX=mitigation
WHITELIST_KEY=whitelist:ips

# ── Nginx Rate Limiting ───────────────────────────────────────────
NGINX_RATE_LIMIT_RPS=50
NGINX_RATE_LIMIT_BURST=100
NGINX_STRICT_RATE_LIMIT_RPS=5
NGINX_STRICT_RATE_LIMIT_BURST=10

# ── Deployment ────────────────────────────────────────────────────
AI_ENGINE_IMAGE=
WORKER_IMAGE=

# ── AWS (local only) ─────────────────────────────────────────────
# AWS_PROFILE=aiops-terraform
# AWS_REGION=ap-southeast-1

# ── Cluster (filled after terraform apply) ────────────────────────
# MASTER_NODE_IP=
# AWS_ACCOUNT_ID=
# MASTER_SSH_PRIVATE_KEY=

# ── GitHub (for sync-secrets.sh) ─────────────────────────────────
# Format: owner/repo-name
GITHUB_REPO=your-username/aiops-traffic-shaper
AWS_GITHUB_ACTIONS_ROLE_ARN=
